<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:id="@+id/rootMain"
    android:background="#111111"
    android:padding="4dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/topControlBar"
        android:background="#000000"
        android:padding="4dp"
        android:layout_width="match_parent"
        android:layout_height="60dp">
        <Button
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnPrevKit"
            android:background="@drawable/btn_3d_blue"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="-"
            android:layout_weight="0.8"/>
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#ffff00"
            android:gravity="center"
            android:id="@+id/txtKitName"
            android:background="#111111"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="3dp"
            android:text="KIT 1"
            android:layout_weight="1.6"/>
        <Button
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnNextKit"
            android:background="@drawable/btn_3d_blue"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="3dp"
            android:text="+"
            android:layout_weight="0.8"/>
        <Button
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnEditMode"
            android:background="@drawable/btn_3d_dark"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="3dp"
            android:text="EDIT"
            android:layout_weight="1.2"/>
        <Button
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnRenameKit"
            android:background="@drawable/btn_3d_purple"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="3dp"
            android:text="NAME"
            android:layout_weight="1.2"/>
        <Button
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnEq"
            android:background="@drawable/btn_3d_dark"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="3dp"
            android:text="FX/ADV"
            android:layout_weight="1.2"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="4dp"
            android:layout_weight="2.2">
            <TextView
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="VOL"/>
            <SeekBar
                android:id="@+id/seekVolume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="4dp"
            android:layout_weight="2.2">
            <TextView
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PITCH"/>
            <SeekBar
                android:id="@+id/seekPitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="150"/>
        </LinearLayout>
        <Button
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnSaveKit"
            android:background="@drawable/btn_glossy_3d"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="4dp"
            android:text="SAVE"
            android:layout_weight="1.2"/>
        <Button
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnLoadKit"
            android:background="@drawable/btn_glossy_3d"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="3dp"
            android:text="LOAD"
            android:layout_weight="1.2"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/fxControlBar"
        android:background="#111111"
        android:padding="2dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="40dp">
        <CheckBox
            android:textSize="10sp"
            android:textColor="#00ffff"
            android:id="@+id/chkDelay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DLY"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#fff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIME"/>
            <SeekBar
                android:id="@+id/seekDelayTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="500"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#fff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LEVEL"/>
            <SeekBar
                android:id="@+id/seekDelayLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"/>
        </LinearLayout>
        <View
            android:background="#444"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_margin="4dp"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#fff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HI-EQ"/>
            <SeekBar
                android:id="@+id/seekEqHigh"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="200"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#fff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MID-EQ"/>
            <SeekBar
                android:id="@+id/seekEqMid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="200"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#fff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOW-EQ"/>
            <SeekBar
                android:id="@+id/seekEqLow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="200"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/advControlBar"
        android:background="#111111"
        android:padding="2dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="40dp">
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#fff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ATTACK"/>
            <SeekBar
                android:id="@+id/seekAttack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="500"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#fff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RELEASE"/>
            <SeekBar
                android:id="@+id/seekRelease"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="500"/>
        </LinearLayout>
        <View
            android:background="#444"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:layout_margin="4dp"/>
        <LinearLayout
            android:gravity="center"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">
            <TextView
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#fff"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHOKE GRP"/>
            <SeekBar
                android:id="@+id/seekChokeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="4"/>
        </LinearLayout>
        <Button
            android:textSize="10sp"
            android:textColor="#ffffff"
            android:id="@+id/btnPadColor"
            android:background="#333333"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="COLOR"
            android:layout_weight="1"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/titleBar"
        android:background="#000000"
        android:padding="6dp"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="4dp">
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#00afff"
            android:id="@+id/txtSelectedPad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SELECTED : PAD 1"/>
        <Button
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnBankToggle"
            android:background="#660000"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginLeft="8dp"
            android:text="BANK A"/>
        <Button
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnLoops"
            android:background="#006600"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginLeft="8dp"
            android:text="LOOPS"/>
        <TextView
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:gravity="center"
            android:id="@+id/txtBrand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="MOBILE OCTAPAD PRAMOD SAHU"
            android:layout_weight="1"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#00ff00"
            android:gravity="center"
            android:id="@+id/txtMidiStatus"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginLeft="8dp"
            android:text="MIDI: disconnected"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/padArea"
        android:padding="2dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_weight="2">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <Button
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/pad1"
                android:background="@drawable/pad_black_selector"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="6dp"
                android:text="PAD 1"
                android:layout_weight="1"/>
            <Button
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/pad2"
                android:background="@drawable/pad_black_selector"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="6dp"
                android:text="PAD 2"
                android:layout_weight="1"/>
            <Button
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/pad3"
                android:background="@drawable/pad_black_selector"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="6dp"
                android:text="PAD 3"
                android:layout_weight="1"/>
            <Button
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/pad4"
                android:background="@drawable/pad_black_selector"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="6dp"
                android:text="PAD 4"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <Button
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/pad5"
                android:background="@drawable/pad_black_selector"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="6dp"
                android:text="PAD 5"
                android:layout_weight="1"/>
            <Button
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/pad6"
                android:background="@drawable/pad_black_selector"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="6dp"
                android:text="PAD 6"
                android:layout_weight="1"/>
            <Button
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/pad7"
                android:background="@drawable/pad_black_selector"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="6dp"
                android:text="PAD 7"
                android:layout_weight="1"/>
            <Button
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/pad8"
                android:background="@drawable/pad_black_selector"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="6dp"
                android:text="PAD 8"
                android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
