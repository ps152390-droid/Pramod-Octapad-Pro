<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#111111"
    android:padding="8dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="#000000"
        android:padding="4dp"
        android:layout_width="match_parent"
        android:layout_height="60dp">
        <Button
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnBack"
            android:background="@drawable/btn_3d_red"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="BACK"
            android:layout_weight="0.8"/>
        <Button
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnPrevLoop"
            android:background="@drawable/btn_3d_blue"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="2dp"
            android:text="-"
            android:layout_weight="0.6"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#ffff00"
            android:gravity="center"
            android:id="@+id/txtLoopChannel"
            android:background="#111111"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="2dp"
            android:text="LOOP 1"
            android:layout_weight="1.4"/>
        <Button
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnNextLoop"
            android:background="@drawable/btn_3d_blue"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="2dp"
            android:text="+"
            android:layout_weight="0.6"/>
        <Button
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnEditLoops"
            android:background="@drawable/btn_3d_dark"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="2dp"
            android:text="EDIT"
            android:layout_weight="1"/>
        <Button
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnRenameLoop"
            android:background="@drawable/btn_3d_purple"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="2dp"
            android:text="NAME"
            android:layout_weight="1"/>
        <Button
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnAdvancedLoops"
            android:background="@drawable/btn_3d_dark"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="2dp"
            android:text="ADV"
            android:layout_weight="1"/>
        <Button
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnSaveLoop"
            android:background="@drawable/btn_glossy_3d"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="2dp"
            android:text="SAVE"
            android:layout_weight="1"/>
        <Button
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:id="@+id/btnLoadLoop"
            android:background="@drawable/btn_3d_orange"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginLeft="2dp"
            android:text="LOAD"
            android:layout_weight="1"/>
    </LinearLayout>
    <TextView
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#00afff"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Mobile Sampler Pramod Sahu"/>
    <TextView
        android:textSize="12sp"
        android:textColor="#ffffff"
        android:gravity="center"
        android:id="@+id/txtLoopStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp"
        android:text="TAP A PAD TO PLAY/STOP LOOP"/>
    <TextView
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#00ff00"
        android:gravity="center"
        android:id="@+id/txtMidiStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="MIDI: disconnected"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/advancedControlPanel"
        android:background="#333333"
        android:padding="8dp"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="MASTER VOL"/>
            <SeekBar
                android:id="@+id/seekMasterVolume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="100"
                android:layout_weight="1"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#00afff"
                android:gravity="end"
                android:id="@+id/txtMasterVolVal"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="100%"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <TextView
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="FX REVERB"/>
            <SeekBar
                android:id="@+id/seekLoopReverb"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="0"
                android:layout_weight="1"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#00afff"
                android:gravity="end"
                android:id="@+id/txtLoopReverbVal"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:text="OFF"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <CheckBox
                android:textSize="12sp"
                android:textColor="#ffffff"
                android:id="@+id/chkMultiMode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="MULTI-PLAY"
                android:layout_weight="1"
                android:buttonTint="#00afff"/>
            <CheckBox
                android:textSize="12sp"
                android:textColor="#ffffff"
                android:id="@+id/chkOneShotMode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="ONE-SHOT"
                android:layout_weight="1"
                android:buttonTint="#00afff"/>
            <Button
                android:textSize="12sp"
                android:textColor="#ffffff"
                android:id="@+id/btnTapTempo"
                android:background="@drawable/btn_3d_purple"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:text="TAP TEMPO"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:background="#222222"
        android:padding="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">
        <TextView
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BPM:"
            android:layout_marginEnd="4dp"/>
        <EditText
            android:textSize="10sp"
            android:textColor="#ffffff"
            android:textColorHint="#888888"
            android:gravity="center"
            android:id="@+id/editCustomBpm"
            android:background="#444444"
            android:padding="2dp"
            android:layout_width="40dp"
            android:layout_height="30dp"
            android:hint="120"
            android:inputType="numberDecimal"/>
        <Button
            android:textSize="8sp"
            android:textColor="#ffffff"
            android:id="@+id/btnSetBpm"
            android:background="@drawable/btn_3d_dark"
            android:layout_width="35dp"
            android:layout_height="30dp"
            android:text="SET"
            android:layout_marginStart="2dp"/>
        <View
            android:background="#555555"
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SPEED:"/>
        <Button
            android:textColor="#ffffff"
            android:id="@+id/btnTempoMinus"
            android:background="@drawable/btn_3d_dark"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:text="-"
            android:layout_marginStart="2dp"/>
        <SeekBar
            android:id="@+id/seekTempo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:layout_weight="1"/>
        <Button
            android:textColor="#ffffff"
            android:id="@+id/btnTempoPlus"
            android:background="@drawable/btn_3d_dark"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:text="+"/>
        <TextView
            android:textSize="10sp"
            android:textColor="#00afff"
            android:gravity="end"
            android:id="@+id/txtTempoVal"
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:text="1.0x"/>
        <View
            android:background="#555555"
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PTCH:"/>
        <SeekBar
            android:id="@+id/seekPitch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:max="200"
            android:progress="100"
            android:layout_weight="1"/>
        <TextView
            android:textSize="10sp"
            android:textColor="#00afff"
            android:gravity="end"
            android:id="@+id/txtPitchVal"
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:text="1.0x"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/loopPadArea"
        android:padding="2dp"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <Button
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/loopPad1"
                android:background="@drawable/pad_black_selector"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="4dp"
                android:text="PAD 1"
                android:layout_weight="1"/>
            <Button
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/loopPad2"
                android:background="@drawable/pad_black_selector"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="4dp"
                android:text="PAD 2"
                android:layout_weight="1"/>
            <Button
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/loopPad3"
                android:background="@drawable/pad_black_selector"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="4dp"
                android:text="PAD 3"
                android:layout_weight="1"/>
            <Button
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/loopPad4"
                android:background="@drawable/pad_black_selector"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="4dp"
                android:text="PAD 4"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <Button
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/loopPad5"
                android:background="@drawable/pad_black_selector"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="4dp"
                android:text="PAD 5"
                android:layout_weight="1"/>
            <Button
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/loopPad6"
                android:background="@drawable/pad_black_selector"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="4dp"
                android:text="PAD 6"
                android:layout_weight="1"/>
            <Button
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/loopPad7"
                android:background="@drawable/pad_black_selector"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="4dp"
                android:text="PAD 7"
                android:layout_weight="1"/>
            <Button
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#ffffff"
                android:id="@+id/loopPad8"
                android:background="@drawable/pad_black_selector"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="4dp"
                android:text="PAD 8"
                android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
