<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#00afff"/>
            <corners android:radius="8dp"/>
            <stroke
                android:width="4dp"
                android:color="#ffffff"/>
        </shape>
    </item>
    <item>
        <layer-list>
            <item
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#3300afff"/>
                    <corners android:radius="12dp"/>
                </shape>
            </item>
            <item
                android:right="4dp"
                android:bottom="4dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#0055aa"
                        android:endColor="#00afff"
                        android:angle="270"/>
                    <corners android:radius="8dp"/>
                    <stroke
                        android:width="2dp"
                        android:color="#00ffff"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
