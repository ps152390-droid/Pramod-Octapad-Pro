<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="#001a33"
                android:endColor="#000814"
                android:angle="270"/>
            <stroke
                android:width="3dp"
                android:color="#00ffff"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:startColor="#003b80"
                android:endColor="#001633"
                android:angle="270"/>
            <stroke
                android:width="2dp"
                android:color="#00afff"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>
