<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item
                android:left="4dp"
                android:top="4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="18dp"/>
                    <gradient
                        android:startColor="#222222"
                        android:endColor="#000000"
                        android:angle="270"
                        android:centerColor="#111111"/>
                    <stroke
                        android:width="3dp"
                        android:color="#00afff"/>
                    <padding
                        android:left="6dp"
                        android:top="6dp"
                        android:right="6dp"
                        android:bottom="6dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item
                android:left="6dp"
                android:top="6dp">
                <shape android:shape="rectangle">
                    <corners android:radius="18dp"/>
                    <solid android:color="#99000000"/>
                </shape>
            </item>
            <item
                android:right="4dp"
                android:bottom="4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="18dp"/>
                    <gradient
                        android:startColor="#444444"
                        android:endColor="#000000"
                        android:angle="270"
                        android:centerColor="#1a1a1a"/>
                    <stroke
                        android:width="2dp"
                        android:color="#808080"/>
                    <padding
                        android:left="6dp"
                        android:top="6dp"
                        android:right="6dp"
                        android:bottom="6dp"/>
                </shape>
            </item>
            <item
                android:right="4dp"
                android:bottom="4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="18dp"/>
                    <gradient
                        android:startColor="#77ffffff"
                        android:endColor="#00ffffff"
                        android:angle="270"
                        android:centerY="0.3"
                        android:centerColor="#11ffffff"/>
                </shape>
            </item>
            <item
                android:right="4dp"
                android:bottom="4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="18dp"/>
                    <gradient
                        android:startColor="#00000000"
                        android:endColor="#aa000000"
                        android:angle="270"
                        android:centerY="0.7"
                        android:centerColor="#00000000"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
