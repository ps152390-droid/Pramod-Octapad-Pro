<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item
                android:left="2dp"
                android:top="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="6dp"/>
                    <gradient
                        android:startColor="#994c00"
                        android:endColor="#e67300"
                        android:angle="270"/>
                    <stroke
                        android:width="1dp"
                        android:color="#ffb266"/>
                    <padding
                        android:left="4dp"
                        android:top="4dp"
                        android:right="4dp"
                        android:bottom="4dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item
                android:left="3dp"
                android:top="3dp">
                <shape>
                    <corners android:radius="6dp"/>
                    <solid android:color="#77000000"/>
                </shape>
            </item>
            <item
                android:right="3dp"
                android:bottom="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="6dp"/>
                    <gradient
                        android:startColor="#ff9933"
                        android:endColor="#cc6600"
                        android:angle="270"/>
                    <stroke
                        android:width="1dp"
                        android:color="#88ffffff"/>
                    <padding
                        android:left="4dp"
                        android:top="4dp"
                        android:right="4dp"
                        android:bottom="4dp"/>
                </shape>
            </item>
            <item
                android:right="3dp"
                android:bottom="3dp">
                <shape>
                    <corners android:radius="6dp"/>
                    <gradient
                        android:startColor="#77ffffff"
                        android:endColor="#00ffffff"
                        android:angle="270"
                        android:centerY="0.3"
                        android:centerColor="#11ffffff"/>
                </shape>
            </item>
            <item
                android:right="3dp"
                android:bottom="3dp">
                <shape>
                    <corners android:radius="6dp"/>
                    <gradient
                        android:startColor="#00000000"
                        android:endColor="#aa000000"
                        android:angle="270"
                        android:centerY="0.7"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
